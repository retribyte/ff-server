{
    "name": "ff-server",
    "version": "1.0.0",
    "description": "My name vortox",
    "main": "server.ts",
    "type": "module",
    "scripts": {
        "dev": "npx tsx src/server.ts",
        "start": "tsc && node dist/server.js",
        "docker:up": "docker compose up -d --build",
        "docker:down": "docker compose down",
        "docs": "npx @redocly/cli lint src/openapi.ts",
        "seed:legacy": "tsx prisma/seed-legacy.ts",
        "seed:8ball": "tsx prisma/seed-8ball.ts",
        "migrate:vm": "tsx prisma/migrate-vm-to-story.ts"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    },
    "author": "Trey R.",
    "dependencies": {
        "@prisma/client": "^6.19.0",
        "@redocly/cli": "^2.30.6",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.21.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "sanitize-html": "^2.17.4",
        "swagger-ui-express": "^5.0.1"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.7",
        "@types/morgan": "^1.9.9",
        "@types/node": "^22.19.19",
        "@types/sanitize-html": "^2.16.1",
        "@types/swagger-ui-express": "^4.1.8",
        "prisma": "^6.19.0",
        "ts-node": "^10.9.2",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2"
    }
