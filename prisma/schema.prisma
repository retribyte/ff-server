datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  USER
  ADMIN
}

enum Sex {
  MALE
  FEMALE
  OTHER
  UNSPECIFIED
}

enum Class {
  BLACK
  HIGHER_SENTIENT
  LOWER_SENTIENT
  NON_SENTIENT
}

enum MessageType {
  BOT_RESPONSE
  COMMAND
  QUOTE
  ACTION
  EMBED
  OTHER
}

enum ItemType {
  WEAPON
  EQUIPMENT
  ARTIFACT
  OTHER
}

enum StoryLineType {
  NARRATION   // prose paragraph
  DIALOGUE    // spoken line, colored by character
  ACTION      // a reader/protagonist choice
  TRANSCRIPT  // in-universe recording fragment (VCOMM etc.)
  BREAK       // scene break
}

enum StoryFormat {
  SCRIPT      // narration and dialogue alternate as whole paragraphs (Vortox Machina)
  PROSE       // novel-style: dialogue embedded inside narration paragraphs
}

model User {
  id            Int         @id @unique @default(autoincrement())
  username      String      @unique
  email         String?     @unique
  password      String      // hashed using bcrypt?
  role          UserRole
  icon          String?     // If null, use identicon?
  bio           String?
  wikiUser      String?
  characters    Character[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  species       Species[]
  messages      Message[]
  items         Item[]
  commentaries  Commentary[]
  stories       Story[]
}

model Character {
  id            Int       @id @unique @default(autoincrement())
  name          String
  dob           Int?      // Date of birth as equinoxes since the GUY epoch (1-1-0 GUY = 13 Mar 1853 BCE). In-universe dates outrange every DB datetime type; see src/utils/guy-time.ts.
  pob           String?   // Place of birth
  aliases       Alias[]   // Array of aliases
  relationships Relationship[] // Array for describing relationships (e.g., "Parent: X", "Sibling: Y")
  homePlanet    String?
  species       Species   @relation(fields: [speciesId], references: [id])
  speciesId     Int
  sex           Sex       // Enum: "Male", "Female", "Other", "Unspecified"
  height        Float?    // Height in meters (e.g., 1.75)
  weight        Float?    // Weight in kilograms
  hairColor     String?
  eyeColor      String?
  creator       User      @relation(fields: [creatorId], references: [id])
  creatorId     Int
  messages      Message[]
  image         String?
  themeColor    String?
  items         Item[]
  blurb         String?
  wikiArticle   String?
  storyLines    StoryLine[]

  @@unique([creatorId, name])
  @@map("characters")
}

model Alias {
  id            Int         @id @unique @default(autoincrement())
  name          String
  characterId   Int
  character     Character   @relation(fields: [characterId], references: [id])

  @@map("aliases")
}

model Relationship {
  id            Int         @id @unique @default(autoincrement())
  description   String      // Example: "Parent of John"
  characterId   Int
  character     Character   @relation(fields: [characterId], references: [id])

  @@map("relationships")
}

model Species {
  id            Int       @id @unique @default(autoincrement())
  name          String
  description   String
  binomialName  String?   // Equivalent to taxonomy
  class         Class     // Enum: "Higher Sentients", "Lower Sentients"
  lifespan      String    // Average lifespan in GUYs
  diet          String?   // Enum: "Carnivore", "Herbivore", "Omnivore", "Other"
  habitat       String?
  placeOfOrigin String?
  creator       User      @relation(fields: [creatorId], references: [id])
  creatorId     Int
  Character     Character[]
  wikiArticle   String?

  @@map("species")
}

model Season {
  title    String         @id @unique
  episodes Episode[]

  @@map("seasons")
}

model Episode {
  title         String      @unique
  season        Season      @relation(fields: [seasonTitle], references: [title])
  episode_no    Int
  messages      Message[]
  seasonTitle   String
  summary       String?
  playedDate    DateTime?

  @@id([seasonTitle, episode_no])
  @@map("episodes")
}

model Message {
  episode       Episode    @relation(fields: [episodeTitle], references: [title])
  messageNo     Int
  episodeTitle  String
  player        User       @relation(fields: [playerId], references: [id])
  playerId      Int
  character     Character? @relation(fields: [characterId], references: [id])
  characterId   Int?
  timestamp     DateTime?
  type          MessageType
  text          String
  commentaries  Commentary[]

  @@id([episodeTitle, messageNo])
  @@map("messages")
}

model Commentary {
  id                  Int     @id @unique @default(autoincrement())
  creator             User    @relation(fields: [creatorId], references: [id])
  creatorId           Int
  message             Message @relation(fields: [messageEpisodeTitle, messageNo], references: [episodeTitle, messageNo])
  messageEpisodeTitle String
  messageNo           Int
  content             String

  @@map("commentaries")
}

// Prose works (short stories, the Vortox Machina chronicle). Unlike the
// season/episode/message hierarchy these use numeric ids + a unique slug so
// renames never cascade through child rows.
model Story {
  id            Int            @id @unique @default(autoincrement())
  slug          String         @unique // URL key, e.g. "vm"
  title         String         @unique
  blurb         String?
  author        User?          @relation(fields: [authorId], references: [id])
  authorId      Int?
  publishedDate DateTime?      // real-world publication; an in-universe date would be a GUY Int
  themeColor    String?
  themeColor2   String?
  format        StoryFormat    @default(SCRIPT) // dialogue presentation: script vs novel-style prose
  chapters      StoryChapter[]

  @@map("stories")
}

model StoryChapter {
  id         Int         @id @unique @default(autoincrement())
  story      Story       @relation(fields: [storyId], references: [id])
  storyId    Int
  chapter_no Int
  title      String?
  lines      StoryLine[]

  @@unique([storyId, chapter_no])
  @@map("story_chapters")
}

model StoryLine {
  id          Int           @id @unique @default(autoincrement())
  chapter     StoryChapter  @relation(fields: [chapterId], references: [id])
  chapterId   Int
  line_no     Int           // 1-based within chapter; deep-link anchor
  type        StoryLineType
  text        String
  character   Character?    @relation(fields: [characterId], references: [id])
  characterId Int?
  speaker     String?       // display-name fallback when no Character row exists
  // Sub-paragraph dialogue spans for novel-style prose: [{text, characterId?, speaker?}]
  // where a segment with a voice is dialogue, one without is narration. The
  // segment texts concatenate verbatim (no separators) to exactly `text`, so
  // search/scan/highlight keep working on `text`. Only set on NARRATION lines.
  // NOTE: segment characterIds live in JSON — no FK, so Character.storyLines
  // does not capture in-paragraph speakers (nothing queries that relation).
  segments    Json?

  @@unique([chapterId, line_no])
  @@map("story_lines")
}

model Item {
  id            Int        @id @unique @default(autoincrement())
  name          String
  itemType      ItemType
  description   String
  image         String?
  creator       User       @relation(fields: [creatorId], references: [id])
  creatorId     Int
  character     Character? @relation(fields: [characterId], references: [id])
  characterId   Int?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  wikiArticle   String?

  @@map("items")
}
