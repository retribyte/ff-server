datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  USER
  ADMIN
}

enum Class {
  BLACK
  HIGHER_SENTIENT
  LOWER_SENTIENT
  NON_SENTIENT
}

enum MessageType {
  BOT_RESPONSE
  COMMAND
  QUOTE
  ACTION
  EMBED
  OTHER
}

enum ItemType {
  WEAPON
  EQUIPMENT
  ARTIFACT
  OTHER
}

enum EightBallAnswerType {
  YES
  NO
  MAYBE
}

enum StoryLineType {
  NARRATION   // prose paragraph
  DIALOGUE    // spoken line, colored by character
  ACTION      // a reader/protagonist choice
  TRANSCRIPT  // in-universe recording fragment (VCOMM etc.)
  BREAK       // scene break
  HEADING     // in-chapter section heading (prose sub-sections)
}

enum StoryFormat {
  SCRIPT      // narration and dialogue alternate as whole paragraphs (Vortox Machina)
  PROSE       // novel-style: dialogue embedded inside narration paragraphs
}

model User {
  id            Int         @id @unique @default(autoincrement())
  username      String      @unique
  email         String?     @unique
  password      String      // hashed using bcrypt?
  role          UserRole
  icon          String?     // If null, use identicon?
  bio           String?
  wikiUser      String?
  characters    Character[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  species       Species[]
  messages      Message[]
  items         Item[]
  commentaries  Commentary[]
  stories       Story[]
}

model Character {
  id            Int       @id @unique @default(autoincrement())
  name          String
  species       Species   @relation(fields: [speciesId], references: [id])
  speciesId     Int
  creator       User      @relation(fields: [creatorId], references: [id])
  creatorId     Int
  messages      Message[]
  image         String?
  color         String?
  blurb         String?
  storyLines    StoryLine[]
  personas      Persona[]
  slug          String    @unique

  @@unique([creatorId, name])
  @@map("characters")
}

// A way a character is presented for some stretch of the archive: a
// different name, a different look, or both. Attached per message via
// Message.personaId — the only presentation mechanism. Named-persona slugs
// are permanent once created (same philosophy as Character/Item/Species).
model Persona {
  id          Int       @id @unique @default(autoincrement())
  name        String?   // null = no name opinion -> canonical name shows
  label       String?   // admin-facing handle ("fungus era", "battle-scarred"); never rendered in transcripts
  slug        String?   @unique // null for name-less personas (no URL identity)
  image       String?   // era avatar; falls back to character.image
  color       String?   // era theme color; falls back to character.color
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterId Int
  messages    Message[]

  @@unique([characterId, name]) // Postgres: NULLs distinct -> many name-less personas allowed
  @@unique([id, characterId])   // composite FK target for Message.persona (retires assertPersonaMatchesCharacter as load-bearing)
  @@map("personas")
}

model Species {
  id            Int       @id @unique @default(autoincrement())
  name          String
  description   String
  class         Class     // Enum: "Higher Sentients", "Lower Sentients"
  creator       User      @relation(fields: [creatorId], references: [id])
  creatorId     Int
  Character     Character[]
  slug          String    @unique

  @@map("species")
}

model Season {
  title    String         @id @unique
  episodes Episode[]
  slug     String         @unique

  @@map("seasons")
}

model Episode {
  title         String      @unique
  season        Season      @relation(fields: [seasonTitle], references: [title])
  episode_no    Int
  messages      Message[]
  seasonTitle   String
  summary       String?
  playedDate    DateTime?
  slug          String      @unique

  @@id([seasonTitle, episode_no])
  @@map("episodes")
}

model Message {
  episode       Episode    @relation(fields: [episodeTitle], references: [title])
  messageNo     Int
  episodeTitle  String
  player        User       @relation(fields: [playerId], references: [id])
  playerId      Int
  character     Character? @relation(fields: [characterId], references: [id])
  characterId   Int?
  persona       Persona?   @relation(fields: [personaId, characterId], references: [id, characterId], onDelete: Restrict)
  personaId     Int?
  timestamp     DateTime?
  type          MessageType
  text          String
  commentaries  Commentary[]

  @@id([episodeTitle, messageNo])
  @@map("messages")
}

model Commentary {
  id                  Int     @id @unique @default(autoincrement())
  creator             User    @relation(fields: [creatorId], references: [id])
  creatorId           Int
  message             Message @relation(fields: [messageEpisodeTitle, messageNo], references: [episodeTitle, messageNo])
  messageEpisodeTitle String
  messageNo           Int
  content             String

  @@map("commentaries")
}

// Prose works (short stories, the Vortox Machina chronicle). Unlike the
// season/episode/message hierarchy these use numeric ids + a unique slug so
// renames never cascade through child rows.
model Story {
  id            Int            @id @unique @default(autoincrement())
  slug          String         @unique
  title         String         @unique
  blurb         String?
  author        User?          @relation(fields: [authorId], references: [id])
  authorId      Int?
  publishedDate DateTime?      // real-world publication; an in-universe date would be a GUY Int
  themeColor    String?
  themeColor2   String?
  format        StoryFormat    @default(SCRIPT) // dialogue presentation: script vs novel-style prose
  chapters      StoryChapter[]

  @@map("stories")
}

model StoryChapter {
  id         Int         @id @unique @default(autoincrement())
  story      Story       @relation(fields: [storyId], references: [id])
  storyId    Int
  chapter_no Int
  title      String?
  lines      StoryLine[]

  @@unique([storyId, chapter_no])
  @@map("story_chapters")
}

model StoryLine {
  id          Int           @id @unique @default(autoincrement())
  chapter     StoryChapter  @relation(fields: [chapterId], references: [id])
  chapterId   Int
  line_no     Int           // 1-based within chapter; deep-link anchor
  type        StoryLineType
  text        String
  character   Character?    @relation(fields: [characterId], references: [id])
  characterId Int?
  speaker     String?       // display-name fallback when no Character row exists
  // Sub-paragraph dialogue spans for novel-style prose: [{text, characterId?, speaker?}]
  // where a segment with a voice is dialogue, one without is narration. The
  // segment texts concatenate verbatim (no separators) to exactly `text`, so
  // search/scan/highlight keep working on `text`. Only set on NARRATION lines.
  // NOTE: segment characterIds live in JSON — no FK, so Character.storyLines
  // does not capture in-paragraph speakers (nothing queries that relation).
  segments    Json?

  @@unique([chapterId, line_no])
  // Containment lookups (`segments @> '[{"characterId": N}]'`) for finding
  // in-paragraph quotes by character — see findQuotesByCharacter in
  // story.service.ts. jsonb_path_ops (not the default jsonb_ops) because the
  // only operator used is `@>`; it's smaller and faster for that one case.
  @@index([segments(ops: JsonbPathOps)], type: Gin)
  @@map("story_lines")
}

model Item {
  id            Int         @id @unique @default(autoincrement())
  name          String
  itemType      ItemType
  description   String
  image         String?
  creator       User        @relation(fields: [creatorId], references: [id])
  creatorId     Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  slug          String      @unique

  @@map("items")
}

model EightBallAnswer {
  id   Int                 @id @default(autoincrement())
  type EightBallAnswerType
  text String

  @@map("eight_ball_answers")
}
